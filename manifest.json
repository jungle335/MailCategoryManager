{
  "manifest_version": 2,
  "name": "Mail Category Manager",
  "version": "1.0",
  "permissions": [
    "identity",
    "notifications",
    "tabs"
  ],
  "content_security_policy": "script-src 'self' https://cdnjs.cloudflare.com; object-src 'self'",
  "background": {
    "scripts": ["config.js", "background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html"
  }
}